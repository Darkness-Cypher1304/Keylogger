# --- 2. FUNCIÓN WIN32 AISLADA (Para evitar congelamiento) ---
def _conseguir_datos_win32():
    """Función síncrona aislada para evitar congelar Discord."""
    try:
        k32 = ctypes.WinDLL('kernel32', use_last_error=True)
        a32 = ctypes.WinDLL('advapi32', use_last_error=True)
        
        comp_buf = ctypes.create_unicode_buffer(16)
        comp_size = ctypes.wintypes.DWORD(16)
        k32.GetComputerNameW(comp_buf, ctypes.byref(comp_size))
        
        user_buf = ctypes.create_unicode_buffer(257)
        user_size = ctypes.wintypes.DWORD(257)
        a32.GetUserNameW(user_buf, ctypes.byref(user_size))
        
        return comp_buf.value, user_buf.value
    except:
        return "Desconocido", "Desconocido"

